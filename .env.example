VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# VAPID — browser-facing public key (also set as VAPID_PUBLIC_KEY for edge functions)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# Server-side only — never expose to the browser
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_CONTACT_EMAIL=admin@yourapp.com
SUPABASE_SERVICE_ROLE_KEY=for_edge_functions_only
